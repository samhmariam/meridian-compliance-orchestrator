      "name": "[guid(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('graphSecretNames')[copyIndex()]), parameters('graphIdentityObjectId'), variables('roleKeyVaultSecretsUser'))]",
      "properties": {

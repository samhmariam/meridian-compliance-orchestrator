{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "11138208112649822214"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "The Azure region for the Day 04 identity resources"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Key Vault housing the secrets"
      }
    },
    "graphSecretNames": {
      "type": "array",
      "metadata": {
        "description": "The names of the Key Vault secrets the execution Graph Host identity may read"
      }
    },
    "erpSecretNames": {
      "type": "array",
      "metadata": {
        "description": "The names of the Key Vault secrets the ERP Writer identity may read"
      }
    },
    "graphIdentityObjectId": {
      "type": "string",
      "metadata": {
        "description": "The object ID of the execution Graph Host identity"
      }
    },
    "ingestIdentityObjectId": {
      "type": "string",
      "metadata": {
        "description": "The object ID of the Ingestion Identity"
      }
    },
    "erpWriterIdentityObjectId": {
      "type": "string",
      "metadata": {
        "description": "The object ID of the ERP Writer identity"
      }
    },
    "searchServiceName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Azure AI Search service used by the graph and ingestion planes"
      }
    },
    "postgresServerName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Azure Database for PostgreSQL Flexible Server storing workflow state"
      }
    },
    "postgresBootstrapAdminObjectId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional dedicated Entra principal object ID used only to bootstrap PostgreSQL database roles"
      }
    },
    "postgresBootstrapAdminPrincipalName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional dedicated Entra principal display name used only to bootstrap PostgreSQL database roles"
      }
    },
    "keyVaultSoftDeleteRetentionDays": {
      "type": "int",
      "defaultValue": 90,
      "minValue": 7,
      "maxValue": 90,
      "metadata": {
        "description": "The Key Vault soft delete retention period in days"
      }
    },
    "searchSkuName": {
      "type": "string",
      "defaultValue": "free",
      "allowedValues": [
        "free",
        "basic"
      ],
      "metadata": {
        "description": "The SKU for the Azure AI Search service. Use free for a single low-cost dev service, or basic if you need a paid tier."
      }
    },
    "searchReplicaCount": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "metadata": {
        "description": "The number of Azure AI Search replicas"
      }
    },
    "searchPartitionCount": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "metadata": {
        "description": "The number of Azure AI Search partitions"
      }
    },
    "postgresBootstrapAdminPrincipalType": {
      "type": "string",
      "defaultValue": "Group",
      "allowedValues": [
        "Group",
        "ServicePrincipal",
        "User"
      ],
      "metadata": {
        "description": "Principal type for the dedicated PostgreSQL bootstrap admin"
      }
    }
  },
  "variables": {
    "roleKeyVaultSecretsUser": "4633458b-17de-408a-b874-0445c86b69e6",
    "roleSearchIndexDataReader": "1407120a-92aa-4202-b7e9-c0e197c71c8f",
    "roleSearchIndexDataContributor": "8ebe5a00-799e-43f5-93ac-243d3dce84a7"
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[parameters('keyVaultName')]",
      "location": "[parameters('location')]",
      "properties": {
        "accessPolicies": [],
        "enableRbacAuthorization": true,
        "enableSoftDelete": true,
        "publicNetworkAccess": "enabled",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "softDeleteRetentionInDays": "[parameters('keyVaultSoftDeleteRetentionDays')]",
        "tenantId": "[tenant().tenantId]"
      }
    },
    {
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2023-11-01",
      "name": "[parameters('searchServiceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "authOptions": {
          "apiKeyOnly": {}
        },
        "disableLocalAuth": false,
        "hostingMode": "default",
        "partitionCount": "[parameters('searchPartitionCount')]",
        "publicNetworkAccess": "enabled",
        "replicaCount": "[parameters('searchReplicaCount')]",
        "semanticSearch": "free"
      },
      "sku": {
        "name": "[parameters('searchSkuName')]"
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-12-01-preview",
      "name": "[parameters('postgresServerName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_B1ms",
        "tier": "Burstable"
      },
      "properties": {
        "version": "16",
        "authConfig": {
          "activeDirectoryAuth": "Enabled",
          "passwordAuth": "Disabled",
          "tenantId": "[tenant().tenantId]"
        }
      }
    },
    {
      "copy": {
        "name": "graphKvAccess",
        "count": "[length(parameters('graphSecretNames'))]"
      },
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('graphSecretNames')[copyIndex()])]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('graphSecretNames')[copyIndex()]), parameters('graphIdentityObjectId'), variables('roleKeyVaultSecretsUser'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleKeyVaultSecretsUser'))]",
        "principalId": "[parameters('graphIdentityObjectId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Search/searchServices', parameters('searchServiceName'))]",
      "name": "[guid(resourceId('Microsoft.Search/searchServices', parameters('searchServiceName')), parameters('graphIdentityObjectId'), variables('roleSearchIndexDataReader'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleSearchIndexDataReader'))]",
        "principalId": "[parameters('graphIdentityObjectId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Search/searchServices', parameters('searchServiceName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/administrators",
      "apiVersion": "2023-12-01-preview",
      "condition": "[and(not(empty(parameters('postgresBootstrapAdminObjectId'))), not(empty(parameters('postgresBootstrapAdminPrincipalName'))))]",
      "name": "[format('{0}/{1}', parameters('postgresServerName'), parameters('postgresBootstrapAdminObjectId'))]",
      "properties": {
        "principalType": "[parameters('postgresBootstrapAdminPrincipalType')]",
        "principalName": "[parameters('postgresBootstrapAdminPrincipalName')]",
        "tenantId": "[tenant().tenantId]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', parameters('postgresServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Search/searchServices', parameters('searchServiceName'))]",
      "name": "[guid(resourceId('Microsoft.Search/searchServices', parameters('searchServiceName')), parameters('ingestIdentityObjectId'), variables('roleSearchIndexDataContributor'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleSearchIndexDataContributor'))]",
        "principalId": "[parameters('ingestIdentityObjectId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Search/searchServices', parameters('searchServiceName'))]"
      ]
    },
    {
      "copy": {
        "name": "erpKvAccess",
        "count": "[length(parameters('erpSecretNames'))]"
      },
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('erpSecretNames')[copyIndex()])]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults/secrets', parameters('keyVaultName'), parameters('erpSecretNames')[copyIndex()]), parameters('erpWriterIdentityObjectId'), variables('roleKeyVaultSecretsUser'))]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('roleKeyVaultSecretsUser'))]",
        "principalId": "[parameters('erpWriterIdentityObjectId')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]"
      ]
    }
  ]
}

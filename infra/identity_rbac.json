    "graphCosmosAssignmentScope": "[if(startsWith(parameters('graphCosmosScope'), '/subscriptions/'), parameters('graphCosmosScope'), if(equals(parameters('graphCosmosScope'), '/'), format('{0}/', resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName'))), format('{0}{1}', resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName')), parameters('graphCosmosScope'))))]",
    "complianceOfficerCosmosAssignmentScope": "[if(startsWith(parameters('complianceOfficerCosmosScope'), '/subscriptions/'), parameters('complianceOfficerCosmosScope'), if(equals(parameters('complianceOfficerCosmosScope'), '/'), format('{0}/', resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName'))), format('{0}{1}', resourceId('Microsoft.DocumentDB/databaseAccounts', parameters('cosmosAccountName')), parameters('complianceOfficerCosmosScope'))))]"
